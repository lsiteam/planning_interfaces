# This service message is retrieve the current Road Plan
uint8 FILTER_NORMAL=0
uint8 FILTER_INTERSECTION=1
uint8 FILTER_EMERGENCY=2
uint8 FILTER_MULTI=3
uint8 FILTER_OVERTAKING=4
uint8 FILTER_TURN=5
uint8 FILTER_BIKE=6
uint8 FILTER_ENTRY=7
uint8 FILTER_EXIT=8
uint8 FILTER_SHOULDER=9
uint8 FILTER_ALL=10

uint8 filter
---
planning_interfaces/RoadPlan road_plan # Road plan currently tracked by the Waypoint Manager
